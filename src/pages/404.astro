---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | Olivebank LC"
  description="The page you are looking for does not exist. Return to the Olivebank LC home page."
>
  <main style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:48px 24px;text-align:center;">
    <p style="font-size:11px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--c-brass);margin-bottom:24px;">
      404
    </p>
    <h1 class="font-display" style="font-size:clamp(3rem,8vw,6rem);line-height:0.94;letter-spacing:-0.04em;color:var(--c-parchment);margin-bottom:28px;">
      Page Not Found.
    </h1>
    <p style="font-size:1rem;line-height:1.8;color:color-mix(in srgb,var(--c-parchment) 60%,transparent);max-width:420px;margin-bottom:48px;">
      The page you are looking for has moved, never existed, or is not ready yet.
    </p>
    <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
      <a
        href="/"
        style="font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-ink);background:var(--c-parchment);padding:14px 28px;transition:opacity 0.2s;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        Back to Home
      </a>
      <a
        href="/services"
        style="font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-parchment);border:1px solid color-mix(in srgb,var(--c-parchment) 25%,transparent);padding:14px 28px;transition:border-color 0.2s;"
        onmouseover="this.style.borderColor='color-mix(in srgb,var(--c-parchment) 60%,transparent)'"
        onmouseout="this.style.borderColor='color-mix(in srgb,var(--c-parchment) 25%,transparent)'"
      >
        View Services
      </a>
      <a
        href="/generator/houston"
        style="font-size:11px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-parchment);border:1px solid color-mix(in srgb,var(--c-parchment) 25%,transparent);padding:14px 28px;transition:border-color 0.2s;"
        onmouseover="this.style.borderColor='color-mix(in srgb,var(--c-parchment) 60%,transparent)'"
        onmouseout="this.style.borderColor='color-mix(in srgb,var(--c-parchment) 25%,transparent)'"
      >
        EOS Backup Energy
      </a>
    </div>
  </main>
</BaseLayout>
