---
import GeneratorLayout from "../../layouts/GeneratorLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "EOS Backup Energy", "item": "https://olivebanklc.com/generator/houston" },
    { "@type": "ListItem", "position": 2, "name": "About" }
  ]
};

// Google Maps embed for EOS Backup Energy and Battery business location
// Locale corrected from pt-BR to en-US
const mapsEmbed = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2289.98192457639!2d-95.44334839999999!3d30.099125899999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864735b28d38cfef%3A0x6a08eed690a8ebd1!2sEos%20Energy%20Backup%20and%20Battery!5e1!3m2!1sen!2sus!4v1774306450802!5m2!1sen!2sus";
---

<GeneratorLayout
  title="About | EOS Backup Energy and Battery | Spring, TX"
  description="Charles Atkins, Spring TX. Sales and business development for home backup power in the Houston area. Real person, honest comparison, no call center."
  city="Houston Metro"
>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="g-nav" aria-label="Site navigation">
    <a href="/generator/houston" class="g-nav-logo">EOS Backup Energy</a>
    <div class="g-nav-links">
      <a href="/generator/houston" class="g-nav-link">Houston</a>
      <a href="/generator/how-it-works" class="g-nav-link">How it works</a>
      <a href="/generator/permits" class="g-nav-link">Permits</a>
    </div>
    <a href="/generator/houston#estimate" class="g-nav-cta">See the math for your home</a>
  </nav>

  <!-- HERO -->
  <div style="padding: 140px 48px 80px; max-width: 1200px; margin: 0 auto; border-bottom: 1px solid var(--g-rule);">
    <p class="g-eyebrow">EOS Backup Energy and Battery | Spring, TX</p>
    <h1 class="g-hero-title" style="font-size: clamp(52px, 6vw, 88px); margin-bottom: 24px;">
      No algorithm.<br />No call center.
    </h1>
    <p style="font-size: 18px; line-height: 1.8; color: var(--g-slate); max-width: 560px;">
      When you submit a form here a real person calls you back. That person is me or someone I work
      directly with.
    </p>
  </div>

  <!-- WHO -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 80px 48px; display: grid; gap: 64px;">

    <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;" class="about-grid">
      <div>
        <div class="g-section-rule"></div>
        <p class="g-section-label">Who is behind this</p>
        <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 3.5vw, 42px); line-height: 1; letter-spacing: 1px; color: var(--g-black); margin-top: 20px;">
          Charles Atkins.<br />Spring, Texas.
        </p>
      </div>
      <div style="display: grid; gap: 18px; padding-top: 8px;">
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          My name is Charles Atkins. I am based in Spring, Texas and I work in sales and business
          development for home backup power systems in the Houston area.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          This site exists because most homeowners shopping for backup power are doing it without good
          information. Generator quotes come without context. Battery options do not come up at all.
          Nobody explains the 10-year math. I do.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          We ask a few questions, explain the options honestly, and either move forward or tell you this
          is not the right fit. No runaround.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          The business behind this site is Olivebank LC, a Texas-based independent operation.
          Installation is coordinated through licensed electricians and certified installers in the
          Houston area.
        </p>
      </div>
    </div>

    <!-- PRODUCT IMAGE: wall-mounted unit -->
    <div class="about-img-break">
      <picture>
        <source srcset="/images/home-reserve-hero.webp" type="image/webp" />
        <img
          src="/images/home-reserve-hero-fallback.jpg"
          alt="Home Reserve whole-home backup power system wall-mounted indoors"
          width="1536"
          height="2048"
          loading="lazy"
          decoding="async"
          class="about-img-full"
        />
      </picture>
      <p class="about-img-caption">Wall-mounted Home Reserve unit. No concrete pad, no outdoor footprint, no exhaust.</p>
    </div>

    <div style="border-top: 1px solid var(--g-rule); padding-top: 64px; display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;" class="about-grid">
      <div>
        <div class="g-section-rule"></div>
        <p class="g-section-label">Why Home Reserve</p>
        <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 3.5vw, 42px); line-height: 1; letter-spacing: 1px; color: var(--g-black); margin-top: 20px;">
          Honest answer.
        </p>
      </div>
      <div style="display: grid; gap: 18px; padding-top: 8px;">
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          Houston is one of the worst major metros in the country for grid reliability. CenterPoint
          improved in 2025 and still ranked last among major utilities nationally. Most Houston homeowners
          have already lived through a dozen outages this year and are quietly wondering if there is a
          better answer than a generator in the backyard.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          Home Reserve is that answer for most of them. I believe that and I will tell you honestly if it
          is not right for your situation.
        </p>
      </div>
    </div>

    <!-- PRODUCT IMAGE: garage install -->
    <div class="about-img-break about-img-break--dark">
      <picture>
        <source srcset="/images/home-reserve-garage.webp" type="image/webp" />
        <img
          src="/images/home-reserve-garage-fallback.jpg"
          alt="Home Reserve battery backup system installed in a residential garage"
          width="2048"
          height="1536"
          loading="lazy"
          decoding="async"
          class="about-img-full"
        />
      </picture>
      <p class="about-img-caption about-img-caption--dark">Garage installation. Fits on any wall — takes up less space than a water heater.</p>
    </div>

    <div style="border-top: 1px solid var(--g-rule); padding-top: 64px; display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;" class="about-grid">
      <div>
        <div class="g-section-rule"></div>
        <p class="g-section-label">What it costs</p>
        <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 3.5vw, 42px); line-height: 1; letter-spacing: 1px; color: var(--g-black); margin-top: 20px;">
          $14,610 equipment.<br />One number.
        </p>
      </div>
      <div style="display: grid; gap: 18px; padding-top: 8px;">
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          Home Reserve equipment is $14,610 before shipping and tax. Installation and permit fees are
          quoted separately based on your home.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          No fuel. No propane. No gas line. No annual maintenance. No repair bills. One purchase,
          10-year warranty, and that is the end of the conversation about ongoing costs.
        </p>
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          Financing is available if you would rather not pay cash upfront. Ask about current terms when
          you reach out.
        </p>
      </div>
    </div>

    <!-- PRODUCT IMAGES: outdoor + night -->
    <div class="about-img-break">
      <div class="about-img-pair">
        <picture>
          <source srcset="/images/home-reserve-outdoor.webp" type="image/webp" />
          <img
            src="/images/home-reserve-outdoor-fallback.jpg"
            alt="Home Reserve unit close-up showing installation quality"
            width="1536"
            height="2048"
            loading="lazy"
            decoding="async"
            class="about-img-full"
          />
        </picture>
        <picture>
          <source srcset="/images/home-reserve-night.webp" type="image/webp" />
          <img
            src="/images/home-reserve-night-fallback.jpg"
            alt="Home Reserve backup power system operating at night during an outage"
            width="1536"
            height="2048"
            loading="lazy"
            decoding="async"
            class="about-img-full"
          />
        </picture>
      </div>
      <p class="about-img-caption">Left: installation detail. Right: the system running silently during a nighttime outage.</p>
    </div>

    <div style="border-top: 1px solid var(--g-rule); padding-top: 64px; display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;" class="about-grid">
      <div>
        <div class="g-section-rule"></div>
        <p class="g-section-label">Location</p>
        <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 3.5vw, 42px); line-height: 1; letter-spacing: 1px; color: var(--g-black); margin-top: 20px;">
          Spring, TX.<br />Houston metro.
        </p>
      </div>
      <div style="padding-top: 8px;">
        <iframe
          src={mapsEmbed}
          width="100%"
          height="320"
          style="border: 1px solid var(--g-rule); display: block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="EOS Backup Energy and Battery location"
        ></iframe>
        <p style="font-size: 12px; color: var(--g-muted); margin-top: 10px; line-height: 1.5;">
          EOS Backup Energy and Battery. Serving Houston, Katy, Sugar Land, Pearland, and The Woodlands.
        </p>
      </div>
    </div>

    <div style="border-top: 1px solid var(--g-rule); padding-top: 64px; display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;" class="about-grid">
      <div>
        <div class="g-section-rule"></div>
        <p class="g-section-label">Contact</p>
        <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(28px, 3.5vw, 42px); line-height: 1; letter-spacing: 1px; color: var(--g-black); margin-top: 20px;">
          Reach out<br />directly.
        </p>
      </div>
      <div style="display: grid; gap: 14px; padding-top: 8px;">
        <p style="font-size: 16px; line-height: 1.85; color: var(--g-slate);">
          Email is the fastest path before submitting a form.
        </p>
        <a
          href="mailto:xavi@olivebanklc.com"
          style="display: inline-block; font-size: 17px; font-weight: 400; color: var(--g-black); border-bottom: 1.5px solid var(--g-amber); padding-bottom: 3px; width: fit-content;"
        >
          xavi@olivebanklc.com
        </a>
        <p style="font-size: 13px; color: var(--g-muted);">
          Phone shared after first contact.
        </p>
      </div>
    </div>

  </div>

  <!-- CTA STRIP -->
  <div style="background: var(--g-black); padding: 72px 48px;">
    <div style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 32px; flex-wrap: wrap;">
      <p style="font-family: 'Bebas Neue', sans-serif; font-size: clamp(32px, 4vw, 52px); line-height: 1; letter-spacing: 1px; color: var(--g-off-white);">
        Get started in your area.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {[
          { label: "Houston", href: "/generator/houston" },
          { label: "Katy", href: "/generator/katy" },
          { label: "Sugar Land", href: "/generator/sugar-land" },
          { label: "Pearland", href: "/generator/pearland" },
          { label: "The Woodlands", href: "/generator/the-woodlands" },
        ].map((city) => (
          <a
            href={`${city.href}#estimate`}
            style="display: inline-block; background: rgba(255,255,255,0.06); color: var(--g-off-white); font-size: 11px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; padding: 12px 20px; border: 1px solid rgba(255,255,255,0.1); transition: border-color 0.2s, background 0.2s;"
          >
            {city.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <footer class="g-footer">
    <p class="g-footer-copy">
      &copy; {new Date().getFullYear()} Olivebank LC | EOS Backup Energy and Battery | Spring, TX
    </p>
    <nav class="g-footer-links" aria-label="Footer navigation">
      <a href="/generator/houston" class="g-footer-link">Houston</a>
      <a href="/generator/how-it-works" class="g-footer-link">How it works</a>
      <a href="/generator/permits" class="g-footer-link">Permits</a>
      <a href="https://olivebanklc.com" class="g-footer-link">Olivebank LC</a>
    </nav>
  </footer>

  <style>
    .about-img-break {
      padding: 48px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .about-img-break--dark {
      background: var(--g-black);
      max-width: 100%;
      padding: 48px;
    }

    .about-img-break--dark .about-img-full,
    .about-img-break--dark .about-img-pair {
      max-width: 1200px;
      margin: 0 auto;
    }

    .about-img-full {
      width: 100%;
      height: auto;
      display: block;
    }

    .about-img-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .about-img-pair img {
      width: 100%;
      height: auto;
      display: block;
    }

    .about-img-caption {
      font-size: 12px;
      color: var(--g-muted);
      letter-spacing: 0.3px;
      line-height: 1.5;
      margin-top: 14px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .about-img-caption--dark {
      color: #908c86;
    }

    @media (max-width: 768px) {
      .about-grid {
        grid-template-columns: 1fr !important;
        gap: 32px !important;
      }
      .about-img-pair {
        grid-template-columns: 1fr;
      }
      .about-img-break,
      .about-img-break--dark {
        padding: 24px;
      }
    }
  </style>

</GeneratorLayout>
